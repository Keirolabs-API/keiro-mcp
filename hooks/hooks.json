{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/keiro-activate.sh\"",
            "commandWindows": "bash \"%CLAUDE_PLUGIN_ROOT%\\hooks\\keiro-activate.sh\"",
            "timeout": 5,
            "statusMessage": "Loading Keiro MCP..."
          }
        ]
      }
    ]
  }
}